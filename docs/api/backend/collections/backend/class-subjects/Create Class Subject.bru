meta {
  name: Create Class Subject
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/class-subjects
  body: json
  auth: inherit
}

body:json {
  {
    "classId": "{{classId}}",
    "academicYearId": "{{academicYearId}}",
    "subjectId": "{{subjectId}}",
    "teacherProfileId": "{{teacherProfileId}}",
    "kkm": 75
  }
}
