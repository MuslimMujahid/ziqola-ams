  url: {{baseUrl}}/assessment-components/type-weights
  body: json
  auth: inherit
}

body:json {
  {
    "teacherSubjectId": "{{classSubjectId}}",
    "academicPeriodId": "{{academicPeriodId}}",
    "assessmentTypeId": "{{assessmentTypeId}}",
    "weight": 40
  }
}
