meta {
  name: Create Teacher Profile
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/profiles/teacher
  body: json
  auth: inherit
}

headers {
  Content-Type: "application/json"
}

body:json {
  {
    "userId": "{{userId}}",
    "nip": "1234567890",
    "nuptk": "1122334455",
    "hiredAt": "2022-01-01",
    "additionalIdentifiers": {
      "externalId": "teacher-001"
    }
  }
}
