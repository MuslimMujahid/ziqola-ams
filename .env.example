# Backend port configuration
PORT=5000
VITE_API_BASE_URL=http://localhost:5000

# PostgreSQL container configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ziqola_ams
POSTGRES_PORT=5432

# Adminer (DB UI) port
ADMINER_PORT=8080

# Local connection string for apps (adjust as needed)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ziqola_ams?schema=public

# JWT configuration
JWT_SECRET=change_me_in_prod
JWT_EXPIRES_IN=86400

# MinIO configurations
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=session-materials

# Ngrok tunnel configuration
# IMPORTANT: inside Docker, do not use localhost; use host.docker.internal for host services
NGROK_AUTHTOKEN=
# NGROK_REGION is deprecated by ngrok v3 and usually not needed
NGROK_REGION=us
NGROK_TARGET=http://host.docker.internal:3000
NGROK_INSPECT_PORT=4040