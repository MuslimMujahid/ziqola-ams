roomAssignment[]\n  schedules                     Schedule[]\n  sessions                      Session[]\n  sessionMaterials              SessionMaterial[]\n  sessionMaterialAttachments    SessionMaterialAttachment[]\n  attendances                   Attendance[]\n  assessmentComponents          AssessmentComponent[]\n  assessmentTypeWeights         AssessmentTypeWeight[]\n  assessmentScores              AssessmentScore[]\n  assessmentSubmissions         AssessmentSubmission[]\n  tenantAssessmentTypes         TenantAssessmentType[]\n  reportCards                   ReportCard[]\n  reportCardSubjects            ReportCardSubject[]\n  auditLogs                     AuditLog[]\n  teacherProfiles               TeacherProfile[]\n  studentProfiles               StudentProfile[]\n  tenantProfileFields           TenantProfileField[]\n  studentProfileFieldValues     StudentProfileFieldValue[]\n  teacherProfileFieldValues     TeacherProfileFieldValue[]\n  tenantConfigurations          TenantConfiguration[]\n  teacherSubjects               TeacherSubject[]\n  assessmentScoreChangeRequests AssessmentScoreChangeRequest[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n}\n\nmodel TenantAssessmentType {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  key         String\n  label       String\n  description String?\n  order       Int?\n  isEnabled   Boolean @default(true)\n\n  sourceTemplateId String?\n\n  components  AssessmentComponent[]\n  typeWeights AssessmentTypeWeight[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, key])\n  @@index([tenantId, isEnabled])\n}\n\nmodel TenantConfiguration {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  configType   TenantConfigurationType\n  templateId   String?\n  isCustomized Boolean                 @default(false)\n  appliedAt    DateTime?\n  templateHash String?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, configType])\n  @@index([tenantId, configType])\n}\n\nmodel User {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  email        String\n  name         String\n  // Store a secure password hash (e.g., bcrypt)\n  passwordHash String\n  role         Role\n\n  status           UserStatus @default(ACTIVE)\n  inviteTokenHash  String?\n  inviteExpiresAt  DateTime?\n  invitedAt        DateTime?\n  lastInviteSentAt DateTime?\n  inviteSentCount  Int        @default(0)\n  invitedById      String?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  // Back-relations (user-level)\n  approvedReportCards ReportCard[]    @relation(\"ReportCardApprovedBy\")\n  auditLogs           AuditLog[]      @relation(\"AuditLogActor\")\n  teacherProfile      TeacherProfile? @relation(\"TeacherProfileUser\")\n  studentProfile      StudentProfile? @relation(\"StudentProfileUser\")\n\n  // Uniqueness of email is scoped per tenant\n  @@unique([tenantId, email])\n  @@index([tenantId, role])\n  @@index([tenantId, status])\n}\n\n// =============================\n// Role-specific Profiles\n// =============================\n\nmodel TeacherProfile {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  userId String @unique\n  user   User   @relation(\"TeacherProfileUser\", fields: [userId], references: [id])\n\n  gender      Gender?\n  dateOfBirth DateTime?\n  phoneNumber String?\n\n  additionalIdentifiers Json?\n\n  hiredAt DateTime?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  // Back-relations (teacher context)\n  homeroomAssignments           HomeroomAssignment[]           @relation(\"HomeroomAssignmentTeacherProfile\")\n  classSubjects                 ClassSubject[]                 @relation(\"ClassSubjectTeacherProfile\")\n  teacherSubjects               TeacherSubject[]\n  assessmentSubmissions         AssessmentSubmission[]\n  assessmentScoreChangeRequests AssessmentScoreChangeRequest[]\n  schedules                     Schedule[]                     @relation(\"ScheduleTeacherProfile\")\n  compiledReportCards           ReportCard[]                   @relation(\"ReportCardCompiledByProfile\")\n  sessionMaterials              SessionMaterial[]\n  customFieldValues             TeacherProfileFieldValue[]\n\n  @@index([tenantId])\n}\n\nmodel StudentProfile {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  userId String @unique\n  user   User   @relation(\"StudentProfileUser\", fields: [userId], references: [id])\n\n  gender      Gender?\n  dateOfBirth DateTime?\n  phoneNumber String?\n\n  nis  String?\n  nisn String?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  // Back-relations (student context)\n  classEnrollments  ClassEnrollment[]          @relation(\"ClassEnrollmentStudentProfile\")\n  attendances       Attendance[]               @relation(\"AttendanceStudentProfile\")\n  assessmentScores  AssessmentScore[]          @relation(\"AssessmentScoreStudentProfile\")\n  reportCards       ReportCard[]               @relation(\"ReportCardStudentProfile\")\n  customFieldValues StudentProfileFieldValue[]\n\n  @@unique([tenantId, nis])\n  @@unique([tenantId, nisn])\n  @@index([tenantId])\n}\n\n// =============================\n// Custom Profile Properties\n// =============================\n\nmodel TenantProfileField {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  role       String\n  key        String\n  label      String\n  type       String\n  helpText   String?\n  options    Json?\n  validation Json?\n  order      Int?\n  isEnabled  Boolean @default(true)\n\n  sourceTemplateId String?\n\n  studentValues StudentProfileFieldValue[]\n  teacherValues TeacherProfileFieldValue[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, role, key])\n  @@index([tenantId, role])\n}\n\nmodel StudentProfileFieldValue {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  studentProfileId String\n  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])\n\n  fieldId String\n  field   TenantProfileField @relation(fields: [fieldId], references: [id])\n\n  valueText        String?\n  valueNumber      Float?\n  valueDate        DateTime?\n  valueBoolean     Boolean?\n  valueSelect      String?\n  valueMultiSelect String[]\n  valueFile        Json?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([studentProfileId, fieldId])\n  @@index([tenantId])\n  @@index([fieldId])\n}\n\nmodel TeacherProfileFieldValue {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id])\n\n  fieldId String\n  field   TenantProfileField @relation(fields: [fieldId], references: [id])\n\n  valueText        String?\n  valueNumber      Float?\n  valueDate        DateTime?\n  valueBoolean     Boolean?\n  valueSelect      String?\n  valueMultiSelect String[]\n  valueFile        Json?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([teacherProfileId, fieldId])\n  @@index([tenantId])\n  @@index([fieldId])\n}\n\n// =============================\n// Academic Structure\n// =============================\n\nmodel AcademicYear {\n  id           String  @id @default(uuid())\n  tenantId     String\n  tenant       Tenant  @relation(\"TenantAcademicYears\", fields: [tenantId], references: [id])\n  activeTenant Tenant? @relation(\"TenantActiveAcademicYear\")\n\n  // Label like \"2025/2026\"\n  label  String\n  status AcademicStatus @default(ACTIVE)\n\n  // Optional dates for the year\n  startDate DateTime?\n  endDate   DateTime?\n\n  // Active period (exactly one active period per year tracked via this pointer)\n  activePeriodId String?         @unique\n  activePeriod   AcademicPeriod? @relation(\"ActivePeriodInYear\", fields: [activePeriodId], references: [id])\n\n  periods             AcademicPeriod[]\n  classes             Class[]\n  classSubjects       ClassSubject[]\n  homeroomAssignments HomeroomAssignment[]\n\n  createdAt DateTime  @default(now())\n  updatedAt DateTime  @updatedAt\n  deletedAt DateTime?\n\n  @@index([tenantId, id, status])\n  @@index([tenantId, deletedAt])\n}\n\nmodel AcademicPeriod {\n  id                   String        @id @default(uuid())\n  tenantId             String\n  tenant               Tenant        @relation(fields: [tenantId], references: [id])\n  academicYearId       String\n  academicYear         AcademicYear  @relation(fields: [academicYearId], references: [id])\n  activeInAcademicYear AcademicYear? @relation(\"ActivePeriodInYear\")\n\n  name       String\n  startDate  DateTime\n  endDate    DateTime\n  orderIndex Int\n  status     PeriodStatus @default(DRAFT)\n\n  schedules                     Schedule[]\n  sessions                      Session[]\n  assessments                   AssessmentComponent[]\n  assessmentTypeWeights         AssessmentTypeWeight[]\n  reportCards                   ReportCard[]\n  assessmentSubmissions         AssessmentSubmission[]\n  assessmentScoreChangeRequests AssessmentScoreChangeRequest[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@index([tenantId, academicYearId, status])\n  @@index([academicYearId, orderIndex])\n}\n\nmodel Class {\n  id             String       @id @default(uuid())\n  tenantId       String\n  tenant         Tenant       @relation(fields: [tenantId], references: [id])\n  academicYearId String\n  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])\n\n  name String\n\n  homeroomAssignments HomeroomAssignment[]\n  classGroups         ClassGroup[]\n  enrollments         ClassEnrollment[]\n  classSubjects       ClassSubject[]\n  schedules           Schedule[]\n  sessions            Session[]\n  reportCards         ReportCard[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, academicYearId, name])\n  @@index([tenantId, academicYearId])\n}\n\nmodel HomeroomAssignment {\n  id               String         @id @default(uuid())\n  tenantId         String\n  tenant           Tenant         @relation(fields: [tenantId], references: [id])\n  classId          String\n  class            Class          @relation(fields: [classId], references: [id])\n  academicYearId   String\n  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id])\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(\"HomeroomAssignmentTeacherProfile\", fields: [teacherProfileId], references: [id])\n  assignedAt       DateTime       @default(now())\n  // Optional end for reassignment scenario within the year\n  endedAt          DateTime?\n  isActive         Boolean        @default(true)\n\n  @@index([tenantId, academicYearId, teacherProfileId])\n  @@index([tenantId, classId, academicYearId, endedAt])\n  @@index([tenantId, classId, academicYearId, isActive])\n}\n\nmodel Group {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  name String\n  type GroupType\n\n  classGroups ClassGroup[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, name, type])\n  @@index([tenantId, type])\n}\n\nmodel ClassGroup {\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n  classId  String\n  groupId  String\n  class    Class  @relation(fields: [classId], references: [id])\n  group    Group  @relation(fields: [groupId], references: [id])\n\n  createdAt DateTime @default(now())\n\n  @@id([classId, groupId])\n  @@index([tenantId, classId])\n}\n\n// Students are represented by users with role STUDENT.\n// Class membership is time-bounded to allow mid-year movement.\nmodel ClassEnrollment {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  classId String\n  class   Class  @relation(fields: [classId], references: [id])\n\n  studentProfileId String\n  studentProfile   StudentProfile @relation(\"ClassEnrollmentStudentProfile\", fields: [studentProfileId], references: [id])\n\n  startDate DateTime\n  endDate   DateTime?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@index([tenantId, classId])\n  @@index([tenantId, studentProfileId])\n}\n\n// =============================\n// Subjects & Teaching Assignment\n// =============================\n\nmodel Subject {\n  id              String           @id @default(uuid())\n  tenantId        String\n  tenant          Tenant           @relation(fields: [tenantId], references: [id])\n  name            String\n  classSubjects   ClassSubject[]\n  teacherSubjects TeacherSubject[]\n  isDeleted       Boolean          @default(false)\n  deletedAt       DateTime?\n  createdAt       DateTime         @default(now())\n  updatedAt       DateTime         @updatedAt\n\n  @@unique([tenantId, name, isDeleted])\n  @@index([tenantId, isDeleted])\n}\n\nmodel ClassSubject {\n  id               String         @id @default(uuid())\n  tenantId         String\n  tenant           Tenant         @relation(fields: [tenantId], references: [id])\n  classId          String\n  class            Class          @relation(fields: [classId], references: [id])\n  academicYearId   String\n  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id])\n  subjectId        String\n  subject          Subject        @relation(fields: [subjectId], references: [id])\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(\"ClassSubjectTeacherProfile\", fields: [teacherProfileId], references: [id])\n  kkm              Int            @default(0)\n\n  schedules                     Schedule[]\n  sessions                      Session[]\n  assessments                   AssessmentComponent[]\n  assessmentSubmissions         AssessmentSubmission[]\n  assessmentScoreChangeRequests AssessmentScoreChangeRequest[]\n  reportCardSubjects            ReportCardSubject[]\n\n  isDeleted Boolean   @default(false)\n  deletedAt DateTime?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([classId, academicYearId, subjectId, isDeleted])\n  @@index([tenantId, teacherProfileId, isDeleted])\n}\n\nmodel TeacherSubject {\n  id               String         @id @default(uuid())\n  tenantId         String\n  tenant           Tenant         @relation(fields: [tenantId], references: [id])\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id])\n  subjectId        String\n  subject          Subject        @relation(fields: [subjectId], references: [id])\n\n  typeWeights AssessmentTypeWeight[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, teacherProfileId, subjectId])\n  @@index([tenantId, teacherProfileId])\n  @@index([tenantId, subjectId])\n}\n\n// =============================\n// Scheduling & Sessions\n// =============================\n\nmodel Schedule {\n  id               String         @id @default(uuid())\n  tenantId         String\n  tenant           Tenant         @relation(fields: [tenantId], references: [id])\n  classId          String\n  class            Class          @relation(fields: [classId], references: [id])\n  academicPeriodId String\n  academicPeriod   AcademicPeriod @relation(fields: [academicPeriodId], references: [id])\n  classSubjectId   String\n  classSubject     ClassSubject   @relation(fields: [classSubjectId], references: [id])\n  // Denormalized teacher profile to enable DB-level conflict constraints\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(\"ScheduleTeacherProfile\", fields: [teacherProfileId], references: [id])\n\n  dayOfWeek Int // 1 (Monday) .. 7 (Sunday)\n  startTime DateTime // Use time component; application can standardize to time-only\n  endTime   DateTime\n\n  sessions Session[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  // Prevent exact start-time collisions for a teacher within a period/day\n  @@unique([teacherProfileId, academicPeriodId, dayOfWeek, startTime])\n  @@index([tenantId, classId, academicPeriodId])\n}\n\nmodel Session {\n  id               String          @id @default(uuid())\n  tenantId         String\n  tenant           Tenant          @relation(fields: [tenantId], references: [id])\n  classId          String\n  class            Class           @relation(fields: [classId], references: [id])\n  academicPeriodId String?\n  academicPeriod   AcademicPeriod? @relation(fields: [academicPeriodId], references: [id])\n  classSubjectId   String\n  classSubject     ClassSubject    @relation(fields: [classSubjectId], references: [id])\n  scheduleId       String?\n  schedule         Schedule?       @relation(fields: [scheduleId], references: [id])\n\n  date      DateTime\n  startTime DateTime\n  endTime   DateTime\n\n  attendance Attendance[]\n  materials  SessionMaterial[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@index([tenantId, classId, classSubjectId])\n  @@index([tenantId, date])\n}\n\nmodel SessionMaterial {\n  id        String  @id @default(uuid())\n  tenantId  String\n  tenant    Tenant  @relation(fields: [tenantId], references: [id])\n  sessionId String\n  session   Session @relation(fields: [sessionId], references: [id])\n\n  content Json?\n  links   String[] @default([])\n\n  createdById String\n  createdBy   TeacherProfile @relation(fields: [createdById], references: [id])\n\n  attachments SessionMaterialAttachment[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, sessionId])\n  @@index([tenantId, createdById])\n}\n\nmodel SessionMaterialAttachment {\n  id                String          @id @default(uuid())\n  tenantId          String\n  tenant            Tenant          @relation(fields: [tenantId], references: [id])\n  sessionMaterialId String\n  sessionMaterial   SessionMaterial @relation(fields: [sessionMaterialId], references: [id])\n\n  fileKey  String\n  fileName String\n  mimeType String\n  size     Int\n\n  createdAt DateTime @default(now())\n\n  @@index([tenantId, sessionMaterialId])\n}\n\nmodel Attendance {\n  id               String           @id @default(uuid())\n  tenantId         String\n  tenant           Tenant           @relation(fields: [tenantId], references: [id])\n  sessionId        String\n  session          Session          @relation(fields: [sessionId], references: [id])\n  studentProfileId String\n  studentProfile   StudentProfile   @relation(\"AttendanceStudentProfile\", fields: [studentProfileId], references: [id])\n  status           AttendanceStatus\n  remarks          String?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([sessionId, studentProfileId])\n  @@index([tenantId, studentProfileId])\n}\n\n// =============================\n// Assessment & Grading\n// =============================\n\nmodel AssessmentComponent {\n  id               String         @id @default(uuid())\n  tenantId         String\n  tenant           Tenant         @relation(fields: [tenantId], references: [id])\n  classSubjectId   String\n  classSubject     ClassSubject   @relation(fields: [classSubjectId], references: [id])\n  academicPeriodId String\n  academicPeriod   AcademicPeriod @relation(fields: [academicPeriodId], references: [id])\n\n  assessmentTypeId String\n  assessmentType   TenantAssessmentType @relation(fields: [assessmentTypeId], references: [id])\n  name             String\n  weight           Int                  @default(0) // Legacy component weight (unused; use AssessmentTypeWeight)\n\n  scores AssessmentScore[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@index([tenantId, assessmentTypeId])\n}\n\nmodel AssessmentTypeWeight {\n  id               String               @id @default(uuid())\n  tenantId         String\n  tenant           Tenant               @relation(fields: [tenantId], references: [id])\n  teacherSubjectId String\n  teacherSubject   TeacherSubject       @relation(fields: [teacherSubjectId], references: [id])\n  academicPeriodId String\n  academicPeriod   AcademicPeriod       @relation(fields: [academicPeriodId], references: [id])\n  assessmentTypeId String\n  assessmentType   TenantAssessmentType @relation(fields: [assessmentTypeId], references: [id])\n  weight           Int // Percentage weight per assessment type\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([teacherSubjectId, academicPeriodId, assessmentTypeId])\n  @@index([tenantId, teacherSubjectId, academicPeriodId])\n  @@index([tenantId, assessmentTypeId])\n}\n\nmodel AssessmentScore {\n  id               String              @id @default(uuid())\n  tenantId         String\n  tenant           Tenant              @relation(fields: [tenantId], references: [id])\n  componentId      String\n  component        AssessmentComponent @relation(fields: [componentId], references: [id])\n  studentProfileId String\n  studentProfile   StudentProfile      @relation(\"AssessmentScoreStudentProfile\", fields: [studentProfileId], references: [id])\n\n  score    Decimal   @db.Decimal(5, 2)\n  isLocked Boolean   @default(false)\n  lockedAt DateTime?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([componentId, studentProfileId])\n  @@index([tenantId, studentProfileId])\n}\n\nmodel AssessmentSubmission {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  classSubjectId String\n  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id])\n\n  academicPeriodId String\n  academicPeriod   AcademicPeriod @relation(fields: [academicPeriodId], references: [id])\n\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id])\n\n  status      String    @default(\"submitted\")\n  submittedAt DateTime  @default(now())\n  returnedAt  DateTime?\n  notes       String?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([classSubjectId, academicPeriodId])\n  @@index([tenantId, classSubjectId, academicPeriodId])\n  @@index([tenantId, teacherProfileId])\n}\n\nmodel AssessmentScoreChangeRequest {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  classSubjectId String\n  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id])\n\n  academicPeriodId String\n  academicPeriod   AcademicPeriod @relation(fields: [academicPeriodId], references: [id])\n\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id])\n\n  status      String    @default(\"pending\")\n  isActive    Boolean   @default(true)\n  requestedAt DateTime  @default(now())\n  resolvedAt  DateTime?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([classSubjectId, academicPeriodId, isActive])\n  @@index([tenantId, classSubjectId, academicPeriodId])\n  @@index([tenantId, teacherProfileId])\n}\n\n// =============================\n// Report Card\n// =============================\n\nmodel ReportCard {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  studentProfileId String\n  studentProfile   StudentProfile @relation(\"ReportCardStudentProfile\", fields: [studentProfileId], references: [id])\n\n  classId String\n  clazz   Class  @relation(fields: [classId], references: [id])\n\n  academicPeriodId String\n  academicPeriod   AcademicPeriod @relation(fields: [academicPeriodId], references: [id])\n\n  status              ReportCardStatus @default(DRAFT)\n  lockedAt            DateTime?\n  approvedById        String?\n  approvedBy          User?            @relation(\"ReportCardApprovedBy\", fields: [approvedById], references: [id])\n  compiledByProfileId String?\n  compiledByProfile   TeacherProfile?  @relation(\"ReportCardCompiledByProfile\", fields: [compiledByProfileId], references: [id])\n  compiledAt          DateTime?\n\n  subjects ReportCardSubject[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([studentProfileId, academicPeriodId])\n  @@index([tenantId, classId])\n}\n\nmodel ReportCardSubject {\n  id             String       @id @default(uuid())\n  tenantId       String\n  tenant         Tenant       @relation(fields: [tenantId], references: [id])\n  reportCardId   String\n  reportCard     ReportCard   @relation(fields: [reportCardId], references: [id])\n  classSubjectId String\n  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id])\n\n  numericScore Decimal     @db.Decimal(5, 2)\n  gradeLetter  GradeLetter\n  description  String?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([reportCardId, classSubjectId])\n  @@index([tenantId, reportCardId])\n}\n\n// =============================\n// Auditing\n// =============================\n\nmodel AuditLog {\n  id         String          @id @default(uuid())\n  tenantId   String\n  tenant     Tenant          @relation(fields: [tenantId], references: [id])\n  entityType AuditEntityType\n  entityId   String\n  action     AuditAction\n  actorId    String\n  actor      User            @relation(\"AuditLogActor\", fields: [actorId], references: [id])\n  timestamp  DateTime        @default(now())\n  metadata   Json?\n\n  @@index([tenantId, entityType, entityId])\n}\n",
+  "inlineSchema": "generator client {\n  provider = \"prisma-client\"\n  output   = \"../src/generated/prisma\"\n}\n\ndatasource db {\n  provider = \"postgresql\"\n}\n\n// =============================\n// Enums\n// =============================\n\nenum Role {\n  PRINCIPAL\n  ADMIN_STAFF\n  TEACHER\n  STUDENT\n}\n\nenum AcademicStatus {\n  ACTIVE\n  ARCHIVED\n}\n\nenum PeriodStatus {\n  DRAFT\n  ARCHIVED\n}\n\nenum GroupType {\n  GRADE\n  STREAM\n  PROGRAM\n  CUSTOM\n}\n\nenum AttendanceStatus {\n  PRESENT\n  EXCUSED\n  SICK\n  ABSENT\n}\n\nenum ReportCardStatus {\n  DRAFT\n  REVIEW\n  APPROVAL\n  LOCKED\n}\n\nenum Gender {\n  MALE\n  FEMALE\n}\n\nenum UserStatus {\n  INVITED\n  ACTIVE\n}\n\nenum GradeLetter {\n  A\n  B\n  C\n  D\n  E\n  F\n}\n\nenum AuditEntityType {\n  GRADE\n  ATTENDANCE\n  REPORT_CARD\n}\n\nenum AuditAction {\n  CREATE\n  UPDATE\n  DELETE\n  LOCK\n  APPROVE\n}\n\nenum TenantConfigurationType {\n  PROFILE\n}\n\n// =============================\n// Core Tenant & Users\n// =============================\n\nmodel Tenant {\n  id                   String        @id @default(uuid())\n  name                 String\n  slug                 String        @unique\n  educationLevel       String?\n  // Points to the currently active academic year (enforces one active per tenant at application level)\n  activeAcademicYearId String?       @unique\n  activeAcademicYear   AcademicYear? @relation(\"TenantActiveAcademicYear\", fields: [activeAcademicYearId], references: [id])\n\n  users                         User[]\n  academicYears                 AcademicYear[]                 @relation(\"TenantAcademicYears\")\n  academicPeriods               AcademicPeriod[]\n  groups                        Group[]\n  subjects                      Subject[]\n  classes                       Class[]\n  classEnrollments              ClassEnrollment[]\n  classSubjects                 ClassSubject[]\n  classGroups                   ClassGroup[]\n  homeroomAssignments           HomeroomAssignment[]\n  schedules                     Schedule[]\n  sessions                      Session[]\n  sessionMaterials              SessionMaterial[]\n  sessionMaterialAttachments    SessionMaterialAttachment[]\n  attendances                   Attendance[]\n  assessmentComponents          AssessmentComponent[]\n  assessmentTypeWeights         AssessmentTypeWeight[]\n  assessmentScores              AssessmentScore[]\n  assessmentSubmissions         AssessmentSubmission[]\n  tenantAssessmentTypes         TenantAssessmentType[]\n  reportCards                   ReportCard[]\n  reportCardSubjects            ReportCardSubject[]\n  auditLogs                     AuditLog[]\n  teacherProfiles               TeacherProfile[]\n  studentProfiles               StudentProfile[]\n  tenantProfileFields           TenantProfileField[]\n  studentProfileFieldValues     StudentProfileFieldValue[]\n  teacherProfileFieldValues     TeacherProfileFieldValue[]\n  tenantConfigurations          TenantConfiguration[]\n  teacherSubjects               TeacherSubject[]\n  assessmentScoreChangeRequests AssessmentScoreChangeRequest[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n}\n\nmodel TenantAssessmentType {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  key         String\n  label       String\n  description String?\n  order       Int?\n  isEnabled   Boolean @default(true)\n\n  sourceTemplateId String?\n\n  components  AssessmentComponent[]\n  typeWeights AssessmentTypeWeight[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, key])\n  @@index([tenantId, isEnabled])\n}\n\nmodel TenantConfiguration {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  configType   TenantConfigurationType\n  templateId   String?\n  isCustomized Boolean                 @default(false)\n  appliedAt    DateTime?\n  templateHash String?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, configType])\n  @@index([tenantId, configType])\n}\n\nmodel User {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  email        String @unique\n  name         String\n  // Store a secure password hash (e.g., bcrypt)\n  passwordHash String\n  role         Role\n\n  status           UserStatus @default(ACTIVE)\n  inviteTokenHash  String?\n  inviteExpiresAt  DateTime?\n  invitedAt        DateTime?\n  lastInviteSentAt DateTime?\n  inviteSentCount  Int        @default(0)\n  invitedById      String?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  // Back-relations (user-level)\n  approvedReportCards ReportCard[]    @relation(\"ReportCardApprovedBy\")\n  auditLogs           AuditLog[]      @relation(\"AuditLogActor\")\n  teacherProfile      TeacherProfile? @relation(\"TeacherProfileUser\")\n  studentProfile      StudentProfile? @relation(\"StudentProfileUser\")\n\n  // Uniqueness of email is now globally scoped\n  @@index([tenantId, role])\n  @@index([tenantId, status])\n}\n\n// =============================\n// Role-specific Profiles\n// =============================\n\nmodel TeacherProfile {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  userId String @unique\n  user   User   @relation(\"TeacherProfileUser\", fields: [userId], references: [id])\n\n  gender      Gender?\n  dateOfBirth DateTime?\n  phoneNumber String?\n\n  additionalIdentifiers Json?\n\n  hiredAt DateTime?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  // Back-relations (teacher context)\n  homeroomAssignments           HomeroomAssignment[]           @relation(\"HomeroomAssignmentTeacherProfile\")\n  classSubjects                 ClassSubject[]                 @relation(\"ClassSubjectTeacherProfile\")\n  teacherSubjects               TeacherSubject[]\n  assessmentSubmissions         AssessmentSubmission[]\n  assessmentScoreChangeRequests AssessmentScoreChangeRequest[]\n  schedules                     Schedule[]                     @relation(\"ScheduleTeacherProfile\")\n  compiledReportCards           ReportCard[]                   @relation(\"ReportCardCompiledByProfile\")\n  sessionMaterials              SessionMaterial[]\n  customFieldValues             TeacherProfileFieldValue[]\n\n  @@index([tenantId])\n}\n\nmodel StudentProfile {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  userId String @unique\n  user   User   @relation(\"StudentProfileUser\", fields: [userId], references: [id])\n\n  gender      Gender?\n  dateOfBirth DateTime?\n  phoneNumber String?\n\n  nis  String?\n  nisn String?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  // Back-relations (student context)\n  classEnrollments  ClassEnrollment[]          @relation(\"ClassEnrollmentStudentProfile\")\n  attendances       Attendance[]               @relation(\"AttendanceStudentProfile\")\n  assessmentScores  AssessmentScore[]          @relation(\"AssessmentScoreStudentProfile\")\n  reportCards       ReportCard[]               @relation(\"ReportCardStudentProfile\")\n  customFieldValues StudentProfileFieldValue[]\n\n  @@unique([tenantId, nis])\n  @@unique([tenantId, nisn])\n  @@index([tenantId])\n}\n\n// =============================\n// Custom Profile Properties\n// =============================\n\nmodel TenantProfileField {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  role       String\n  key        String\n  label      String\n  type       String\n  helpText   String?\n  options    Json?\n  validation Json?\n  order      Int?\n  isEnabled  Boolean @default(true)\n\n  sourceTemplateId String?\n\n  studentValues StudentProfileFieldValue[]\n  teacherValues TeacherProfileFieldValue[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, role, key])\n  @@index([tenantId, role])\n}\n\nmodel StudentProfileFieldValue {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  studentProfileId String\n  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])\n\n  fieldId String\n  field   TenantProfileField @relation(fields: [fieldId], references: [id])\n\n  valueText        String?\n  valueNumber      Float?\n  valueDate        DateTime?\n  valueBoolean     Boolean?\n  valueSelect      String?\n  valueMultiSelect String[]\n  valueFile        Json?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([studentProfileId, fieldId])\n  @@index([tenantId])\n  @@index([fieldId])\n}\n\nmodel TeacherProfileFieldValue {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id])\n\n  fieldId String\n  field   TenantProfileField @relation(fields: [fieldId], references: [id])\n\n  valueText        String?\n  valueNumber      Float?\n  valueDate        DateTime?\n  valueBoolean     Boolean?\n  valueSelect      String?\n  valueMultiSelect String[]\n  valueFile        Json?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([teacherProfileId, fieldId])\n  @@index([tenantId])\n  @@index([fieldId])\n}\n\n// =============================\n// Academic Structure\n// =============================\n\nmodel AcademicYear {\n  id           String  @id @default(uuid())\n  tenantId     String\n  tenant       Tenant  @relation(\"TenantAcademicYears\", fields: [tenantId], references: [id])\n  activeTenant Tenant? @relation(\"TenantActiveAcademicYear\")\n\n  // Label like \"2025/2026\"\n  label  String\n  status AcademicStatus @default(ACTIVE)\n\n  // Optional dates for the year\n  startDate DateTime?\n  endDate   DateTime?\n\n  // Active period (exactly one active period per year tracked via this pointer)\n  activePeriodId String?         @unique\n  activePeriod   AcademicPeriod? @relation(\"ActivePeriodInYear\", fields: [activePeriodId], references: [id])\n\n  periods             AcademicPeriod[]\n  classes             Class[]\n  classSubjects       ClassSubject[]\n  homeroomAssignments HomeroomAssignment[]\n\n  createdAt DateTime  @default(now())\n  updatedAt DateTime  @updatedAt\n  deletedAt DateTime?\n\n  @@index([tenantId, id, status])\n  @@index([tenantId, deletedAt])\n}\n\nmodel AcademicPeriod {\n  id                   String        @id @default(uuid())\n  tenantId             String\n  tenant               Tenant        @relation(fields: [tenantId], references: [id])\n  academicYearId       String\n  academicYear         AcademicYear  @relation(fields: [academicYearId], references: [id])\n  activeInAcademicYear AcademicYear? @relation(\"ActivePeriodInYear\")\n\n  name       String\n  startDate  DateTime\n  endDate    DateTime\n  orderIndex Int\n  status     PeriodStatus @default(DRAFT)\n\n  schedules                     Schedule[]\n  sessions                      Session[]\n  assessments                   AssessmentComponent[]\n  assessmentTypeWeights         AssessmentTypeWeight[]\n  reportCards                   ReportCard[]\n  assessmentSubmissions         AssessmentSubmission[]\n  assessmentScoreChangeRequests AssessmentScoreChangeRequest[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@index([tenantId, academicYearId, status])\n  @@index([academicYearId, orderIndex])\n}\n\nmodel Class {\n  id             String       @id @default(uuid())\n  tenantId       String\n  tenant         Tenant       @relation(fields: [tenantId], references: [id])\n  academicYearId String\n  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])\n\n  name String\n\n  homeroomAssignments HomeroomAssignment[]\n  classGroups         ClassGroup[]\n  enrollments         ClassEnrollment[]\n  classSubjects       ClassSubject[]\n  schedules           Schedule[]\n  sessions            Session[]\n  reportCards         ReportCard[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, academicYearId, name])\n  @@index([tenantId, academicYearId])\n}\n\nmodel HomeroomAssignment {\n  id               String         @id @default(uuid())\n  tenantId         String\n  tenant           Tenant         @relation(fields: [tenantId], references: [id])\n  classId          String\n  class            Class          @relation(fields: [classId], references: [id])\n  academicYearId   String\n  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id])\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(\"HomeroomAssignmentTeacherProfile\", fields: [teacherProfileId], references: [id])\n  assignedAt       DateTime       @default(now())\n  // Optional end for reassignment scenario within the year\n  endedAt          DateTime?\n  isActive         Boolean        @default(true)\n\n  @@index([tenantId, academicYearId, teacherProfileId])\n  @@index([tenantId, classId, academicYearId, endedAt])\n  @@index([tenantId, classId, academicYearId, isActive])\n}\n\nmodel Group {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  name String\n  type GroupType\n\n  classGroups ClassGroup[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, name, type])\n  @@index([tenantId, type])\n}\n\nmodel ClassGroup {\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n  classId  String\n  groupId  String\n  class    Class  @relation(fields: [classId], references: [id])\n  group    Group  @relation(fields: [groupId], references: [id])\n\n  createdAt DateTime @default(now())\n\n  @@id([classId, groupId])\n  @@index([tenantId, classId])\n}\n\n// Students are represented by users with role STUDENT.\n// Class membership is time-bounded to allow mid-year movement.\nmodel ClassEnrollment {\n  id       String @id @default(uuid())\n  tenantId String\n  tenant   Tenant @relation(fields: [tenantId], references: [id])\n\n  classId String\n  class   Class  @relation(fields: [classId], references: [id])\n\n  studentProfileId String\n  studentProfile   StudentProfile @relation(\"ClassEnrollmentStudentProfile\", fields: [studentProfileId], references: [id])\n\n  startDate DateTime\n  endDate   DateTime?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@index([tenantId, classId])\n  @@index([tenantId, studentProfileId])\n}\n\n// =============================\n// Subjects & Teaching Assignment\n// =============================\n\nmodel Subject {\n  id              String           @id @default(uuid())\n  tenantId        String\n  tenant          Tenant           @relation(fields: [tenantId], references: [id])\n  name            String\n  classSubjects   ClassSubject[]\n  teacherSubjects TeacherSubject[]\n  isDeleted       Boolean          @default(false)\n  deletedAt       DateTime?\n  createdAt       DateTime         @default(now())\n  updatedAt       DateTime         @updatedAt\n\n  @@unique([tenantId, name, isDeleted])\n  @@index([tenantId, isDeleted])\n}\n\nmodel ClassSubject {\n  id               String         @id @default(uuid())\n  tenantId         String\n  tenant           Tenant         @relation(fields: [tenantId], references: [id])\n  classId          String\n  class            Class          @relation(fields: [classId], references: [id])\n  academicYearId   String\n  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id])\n  subjectId        String\n  subject          Subject        @relation(fields: [subjectId], references: [id])\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(\"ClassSubjectTeacherProfile\", fields: [teacherProfileId], references: [id])\n  kkm              Int            @default(0)\n\n  schedules                     Schedule[]\n  sessions                      Session[]\n  assessments                   AssessmentComponent[]\n  assessmentSubmissions         AssessmentSubmission[]\n  assessmentScoreChangeRequests AssessmentScoreChangeRequest[]\n  reportCardSubjects            ReportCardSubject[]\n\n  isDeleted Boolean   @default(false)\n  deletedAt DateTime?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([classId, academicYearId, subjectId, isDeleted])\n  @@index([tenantId, teacherProfileId, isDeleted])\n}\n\nmodel TeacherSubject {\n  id               String         @id @default(uuid())\n  tenantId         String\n  tenant           Tenant         @relation(fields: [tenantId], references: [id])\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(fields: [teacherProfileId], references: [id])\n  subjectId        String\n  subject          Subject        @relation(fields: [subjectId], references: [id])\n\n  typeWeights AssessmentTypeWeight[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, teacherProfileId, subjectId])\n  @@index([tenantId, teacherProfileId])\n  @@index([tenantId, subjectId])\n}\n\n// =============================\n// Scheduling & Sessions\n// =============================\n\nmodel Schedule {\n  id               String         @id @default(uuid())\n  tenantId         String\n  tenant           Tenant         @relation(fields: [tenantId], references: [id])\n  classId          String\n  class            Class          @relation(fields: [classId], references: [id])\n  academicPeriodId String\n  academicPeriod   AcademicPeriod @relation(fields: [academicPeriodId], references: [id])\n  classSubjectId   String\n  classSubject     ClassSubject   @relation(fields: [classSubjectId], references: [id])\n  // Denormalized teacher profile to enable DB-level conflict constraints\n  teacherProfileId String\n  teacherProfile   TeacherProfile @relation(\"ScheduleTeacherProfile\", fields: [teacherProfileId], references: [id])\n\n  dayOfWeek Int // 1 (Monday) .. 7 (Sunday)\n  startTime DateTime // Use time component; application can standardize to time-only\n  endTime   DateTime\n\n  sessions Session[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  // Prevent exact start-time collisions for a teacher within a period/day\n  @@unique([teacherProfileId, academicPeriodId, dayOfWeek, startTime])\n  @@index([tenantId, classId, academicPeriodId])\n}\n\nmodel Session {\n  id               String          @id @default(uuid())\n  tenantId         String\n  tenant           Tenant          @relation(fields: [tenantId], references: [id])\n  classId          String\n  class            Class           @relation(fields: [classId], references: [id])\n  academicPeriodId String?\n  academicPeriod   AcademicPeriod? @relation(fields: [academicPeriodId], references: [id])\n  classSubjectId   String\n  classSubject     ClassSubject    @relation(fields: [classSubjectId], references: [id])\n  scheduleId       String?\n  schedule         Schedule?       @relation(fields: [scheduleId], references: [id])\n\n  date      DateTime\n  startTime DateTime\n  endTime   DateTime\n\n  attendance Attendance[]\n  materials  SessionMaterial[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@index([tenantId, classId, classSubjectId])\n  @@index([tenantId, date])\n}\n\nmodel SessionMaterial {\n  id        String  @id @default(uuid())\n  tenantId  String\n  tenant    Tenant  @relation(fields: [tenantId], references: [id])\n  sessionId String\n  session   Session @relation(fields: [sessionId], references: [id])\n\n  content Json?\n  links   String[] @default([])\n\n  createdById String\n  createdBy   TeacherProfile @relation(fields: [createdById], references: [id])\n\n  attachments SessionMaterialAttachment[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([tenantId, sessionId])\n  @@index([tenantId, createdById])\n}\n\nmodel SessionMaterialAttachment {\n  id                String          @id @default(uuid())\n  tenantId          String\n  tenant            Tenant          @relation(fields: [tenantId], references: [id])\n  sessionMaterialId String\n  sessionMaterial   SessionMaterial @relation(fields: [sessionMaterialId], references: [id])\n\n  fileKey  String\n  fileName String\n  mimeType String\n  size     Int\n\n  createdAt DateTime @default(now())\n\n  @@index([tenantId, sessionMaterialId])\n}\n\nmodel Attendance {\n  id               String           @id @default(uuid())\n  tenantId         String\n  tenant           Tenant           @relation(fields: [tenantId], references: [id])\n  sessionId        String\n  session          Session          @relation(fields: [sessionId], references: [id])\n  studentProfileId String\n  studentProfile   StudentProfile   @relation(\"AttendanceStudentProfile\", fields: [studentProfileId], references: [id])\n  status           AttendanceStatus\n  remarks          String?\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([sessionId, studentProfileId])\n  @@index([tenantId, studentProfileId])\n}\n\n// =============================\n// Assessment & Grading\n// =============================\n\nmodel AssessmentComponent {\n  id               String         @id @default(uuid())\n  tenantId         String\n  tenant           Tenant         @relation(fields: [tenantId], references: [id])\n  classSubjectId   String\n  classSubject     ClassSubject   @relation(fields: [classSubjectId], references: [id])\n  academicPeriodId String\n  academicPeriod   AcademicPeriod @relation(fields: [academicPeriodId], references: [id])\n\n  assessmentTypeId String\n  assessmentType   TenantAssessmentType @relation(fields: [assessmentTypeId], references: [id])\n  name             String\n  weight           Int                  @default(0) // Legacy component weight (unused; use AssessmentTypeWeight)\n\n  scores AssessmentScore[]\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@index([tenantId, assessmentTypeId])\n}\n\nmodel AssessmentTypeWeight {\n  id               String               @id @default(uuid())\n  tenantId         String\n  tenant           Tenant               @relation(fields: [tenantId], references: [id])\n  teacherSubjectId String\n  teacherSubject   TeacherSubject       @relation(fields: [teacherSubjectId], references: [id])\n  academicPeriodId String\n  academicPeriod   AcademicPeriod       @relation(fields: [academicPeriodId], references: [id])\n  assessmentTypeId String\n  assessmentType   TenantAssessmentType @relation(fields: [assessmentTypeId], references: [id])\n  weight           Int // Percentage weight per assessment type\n\n  createdAt DateTime @default(now())\n  updatedAt DateTime @updatedAt\n\n  @@unique([teacherSubjectId, academicPeriodId, assessmentTypeId])\n  @@index([tenantId, teacherSubjectId, academicPeriodId])\n  @@index([tenantId, assessmentTypeId])\n}\n\nmodel AssessmentScore {\n  id               String              @id @default(uuid())\n  tenantId         String\n  tenant           Tenant              @relation(fields: [tenantId], references: [id])\n  componentId      String\n  component        AssessmentComponent @relation(fields: [componentId], references: [id])\n  studentProfileId String\n  studentProfile   StudentProfile      @relation(\"AssessmentScoreStudentProfile\", fields: [studentProfileId], references: [id])\n\n  score    Decimal 