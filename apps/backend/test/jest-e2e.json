{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": ["node_modules/(?!@repo)"],
  "moduleNameMapper": {
    "^@repo/db$": "<rootDir>/../node_modules/@repo/db/dist/index.cjs"
  }
}
