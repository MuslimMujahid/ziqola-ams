{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "src/assets/prisma-cjs-package.json",
        "outDir": "dist/generated/prisma",
        "rename": "package.json"
      },
      {
        "include": "src/configurations/templates/*.json",
        "outDir": "dist/configurations/templates"
      }
    ]
  }
}
